# Copy to `.env` and uncomment values you need. Used at **build time** by `astro.config.mjs`
# (CI sets these in `.github/workflows/deploy-github-pages.yml` instead).

# --- Canonical site URL (RSS, sitemap, Open Graph) ---
# Root deploy (custom domain or user/org GitHub Pages site):
# SITE_URL=https://example.com
# BASE_PATH=/

# Project repo on GitHub Pages (`https://owner.github.io/repo-name/`):
# SITE_URL=https://yourname.github.io/your-repo
# BASE_PATH=/your-repo/

# Aliases (same effect as SITE_URL / BASE_PATH):
# PUBLIC_SITE_URL=https://example.com
# PUBLIC_BASE_PATH=/docs/
